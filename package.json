{
  "name": "nezha",
  "version": "0.0.1",
  "description": "An customized assistant base on pi-mono",
  "type": "module",
  "piConfig": {
    "name": "nezha",
    "configDir": "nezha-workspace"
  },
  "bin": {
    "nezha": "dist/main.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && shx chmod +x dist/main.js",
