    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mariozechner/jiti": "^2.6.2",
    "@mariozechner/pi-ai": "^0.60.0",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@types/js-yaml": "^4.0.9",
    "axios": "^1.13.6",
    "chalk": "^5.5.0",
    "dotenv": "^17.3.1",
    "events": "^3.0.0",
    "js-yaml": "^4.1.1",
    "ws": "8.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "shx": "^0.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@8.7.6+sha1.a428b12202bc4f23b17e6dffe730734dae5728e2"
